{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "moderator", "user"] },
        "isActive": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "role", "isActive"]
    },
    "Establishment": {
      "title": "Establishment",
      "description": "A business or place of interest",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "wilaya": { "type": "string" },
        "commune": { "type": "string" },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "media": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "categoryId", "wilaya", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "User review of an establishment",
      "type": "object",
      "properties": {
        "establishmentId": { "type": "string" },
        "establishmentName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["establishmentId", "userId", "rating", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Business category",
      "type": "object",
      "properties": {
        "name": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "fr": { "type": "string" },
            "ar": { "type": "string" }
          }
        },
        "iconName": { "type": "string" }
      },
      "required": ["name", "iconName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/establishments/{establishmentId}": {
      "schema": "Establishment",
      "description": "Establishment records"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User reviews"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Business categories"
    }
  }
}
