rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isVerified() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        ((request.auth.token.email == 'mohamedsenator5@gmail.com' || request.auth.token.email == 'brardadz0531@gmail.com') && request.auth.token.email_verified == true)
      );
    }

    function isModerator() {
      return isAdmin() || (isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'admin' || getUserData().role == 'moderator'));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['displayName', 'email', 'role', 'isActive'])
          && data.displayName is string && data.displayName.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.role in ['admin', 'moderator', 'user']
          && data.isActive is bool;
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
        incoming().role == 'user' || 
        ((request.auth.token.email == 'mohamedsenator5@gmail.com' || request.auth.token.email == 'brardadz0531@gmail.com') && request.auth.token.email_verified == true && incoming().role == 'admin')
      );
      allow update: if isVerified() && (
        (isAdmin() && isValidUser(incoming())) ||
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) && isValidUser(incoming()))
      );
    }

    // --- Establishments ---
    match /establishments/{establishmentId} {
      function isValidEstablishment(data) {
        return data.keys().hasAll(['title', 'categoryId', 'wilaya', 'status'])
          && data.title is string && data.title.size() <= 200
          && data.categoryId is string && data.categoryId.size() <= 64
          && data.status in ['active', 'inactive'];
      }

      allow read: if true; // Publicly readable
      allow create: if isModerator() && isValidId(establishmentId) && isValidEstablishment(incoming());
      allow update: if isModerator() && isValidEstablishment(incoming());
      allow delete: if isAdmin();
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.keys().hasAll(['establishmentId', 'userId', 'rating', 'comment', 'status'])
          && data.establishmentId is string && data.establishmentId.size() <= 64
          && data.userId is string && data.userId.size() <= 64
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.comment is string && data.comment.size() <= 1000
          && data.status in ['pending', 'approved', 'rejected'];
      }

      allow get: if true;
      allow list: if isAdmin() || isModerator();
      allow create: if isVerified() && isValidId(reviewId) && isValidReview(incoming()) && incoming().status == 'pending';
      allow update: if isModerator() && (incoming().diff(existing()).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin() || (isVerified() && existing().userId == request.auth.uid);
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(categoryId);
    }

    // --- Analytics ---
    match /analytics/{analyticsDoc=**} {
      allow read: if isModerator();
      // Write is restricted, normally handled by increment logic or cloud functions
    }
  }
}
